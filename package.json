{
  "name": "@tamer4lynx/tamer-insets",
  "publishConfig": {
    "access": "public",
    "tag": "prerelease"
  },
  "version": "0.0.5",
  "type": "module",
  "description": "Hooks for system insets and keyboard state in Lynx.",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",

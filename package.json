  "lynx": {
    "ext": "lynx.ext.json"
  },
  "scripts": {
    "build": "tsc"
  },
  "peerDependencies": {
    "react": "^17.0.0"
  },
  "devDependencies": {
    "@types/react": "^17.0.0",
    "react": "^17.0.2",
    "typescript": "~5.8.0"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tamer4lynx/tamer-insets.git"
  },
  "homepage": "https://github.com/tamer4lynx/tamer-insets#readme",
